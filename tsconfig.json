{
	"compilerOptions": {
		"strict": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"jsx": "react-jsx",
		"module": "preserve",
		"moduleResolution": "bundler",
		"target": "ES2022",
		"lib": ["ES2023", "DOM", "DOM.Iterable"],
		"types": ["@cloudflare/workers-types", "vite/client"],
		"noEmit": true,
		"skipLibCheck": true,
		"paths": {
			"#/*": ["./src/*"]
		}
	},
	"include": ["src", "worker-configuration.d.ts", "vite.config.ts"]
}
