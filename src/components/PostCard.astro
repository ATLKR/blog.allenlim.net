---
import { formatDate } from "../lib/site";

interface Props {
	title: string;
	excerpt?: string | null;
	href: string;
	date?: string | null;
	readingTime?: number;
	visibility?: string;
	tags?: Array<{ slug: string; label: string }>;
}

const { title, excerpt, href, date, readingTime, visibility, tags = [] } = Astro.props;
const dateStr = formatDate(date);
---

<article class="post-card">
	<div class="card-meta">
		{dateStr && <time>{dateStr}</time>}
		{readingTime && <><span class="dot" /><span>{readingTime} min read</span></>}
		{visibility && visibility !== "public" && <span class={`badge badge-${visibility}`}>{visibility}</span>}
	</div>
	<a href={href} class="card-title-link"><h2 class="card-title">{title}</h2></a>
	{excerpt && <p class="card-excerpt">{excerpt}</p>}
	{tags.length > 0 && (
		<div class="card-tags">
			{tags.map((t) => <a href={`/tag/${t.slug}`} class="tag">{t.label}</a>)}
		</div>
	)}
</article>

<style>
	.post-card {
		padding: var(--spacing-6) 0;
		border-bottom: 1px solid var(--color-border-subtle);
	}
	.card-meta {
		display: flex;
		align-items: center;
		gap: var(--spacing-3);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		margin-bottom: var(--spacing-2);
	}
	.dot {
		width: 3px;
		height: 3px;
		border-radius: 50%;
		background: var(--color-muted);
	}
	.badge {
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
		font-size: var(--font-size-xs);
		padding: 1px var(--spacing-2);
		border-radius: var(--radius);
		background: var(--color-surface);
		color: var(--color-text-secondary);
	}
	.badge-draft { color: #b45309; }
	.badge-private { color: #b91c1c; }
	.badge-unlisted { color: #6d28d9; }
	.card-title-link {
		color: inherit;
	}
	.card-title {
		font-size: var(--font-size-2xl);
		font-weight: 600;
		transition: color var(--transition-fast);
	}
	.card-title-link:hover .card-title {
		color: var(--color-accent);
	}
	.card-excerpt {
		margin-top: var(--spacing-2);
		color: var(--color-text-secondary);
	}
	.card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
		margin-top: var(--spacing-3);
	}
	.tag {
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		background: var(--color-surface);
		padding: var(--spacing-1) var(--spacing-3);
		border-radius: var(--radius);
	}
	.tag:hover {
		background: var(--color-border);
		color: var(--color-text);
	}
</style>
