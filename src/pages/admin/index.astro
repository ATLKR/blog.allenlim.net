---
import Admin from "../../layouts/Admin.astro";
import { listPosts } from "../../lib/content";
import { formatDate } from "../../lib/site";

const env = Astro.locals.env;
const posts = env ? await listPosts(env, { includeHidden: true, limit: 500 }) : [];
const counts = posts.reduce<Record<string, number>>((acc, p) => {
	acc[p.visibility] = (acc[p.visibility] ?? 0) + 1;
	return acc;
}, {});
---

<Admin title="Posts">
	<div class="head">
		<div>
			<h1>Posts</h1>
			<p class="sub">
				{posts.length} total · {counts.public ?? 0} public · {counts.unlisted ?? 0} unlisted ·
				{counts.private ?? 0} private · {counts.draft ?? 0} draft
			</p>
		</div>
		<a href="/admin/posts/new" class="btn">New post</a>
	</div>

	{posts.length === 0 ? (
		<p class="empty">No posts yet. Create your first one.</p>
	) : (
		<table class="posts">
			<thead>
				<tr><th>Title</th><th>Visibility</th><th>Updated</th></tr>
			</thead>
			<tbody>
				{posts.map((p) => (
					<tr>
						<td><a href={`/admin/posts/${p.id}`} class="t">{p.title}</a><div class="slug">/{p.slug}</div></td>
						<td><span class={`badge badge-${p.visibility}`}>{p.visibility}</span></td>
						<td class="when">{formatDate(p.updated_at)}</td>
					</tr>
				))}
			</tbody>
		</table>
	)}
</Admin>

<style>
	.head { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.5rem; }
	.head h1 { font-size: 1.6rem; }
	.sub { color: var(--muted); font-size: 0.85rem; margin-top: 0.3rem; }
	.empty { color: var(--muted); }
	.posts { width: 100%; border-collapse: collapse; font-size: 0.92rem; }
	.posts th { text-align: left; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); padding: 0.5rem 0.6rem; border-bottom: 1px solid var(--border); }
	.posts td { padding: 0.7rem 0.6rem; border-bottom: 1px solid var(--border); vertical-align: top; }
	.t { font-weight: 500; color: var(--text); }
	.t:hover { color: var(--accent); }
	.slug { color: var(--muted); font-size: 0.78rem; margin-top: 0.15rem; }
	.when { color: var(--muted); white-space: nowrap; }
	.badge { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.1rem 0.45rem; border-radius: 4px; background: var(--panel); border: 1px solid var(--border); }
	.badge-public { color: #15803d; }
	.badge-draft { color: #b45309; }
	.badge-private { color: var(--danger); }
	.badge-unlisted { color: #6d28d9; }
</style>
