---
import Admin from "../../../layouts/Admin.astro";
import PostEditor from "../../../components/PostEditor.astro";
import { getPostMetaById, loadBody } from "../../../lib/content";

const env = Astro.locals.env;
const id = Astro.params.id!;
const post = env ? await getPostMetaById(env, id) : null;
if (!post) return Astro.redirect("/admin");

const body = await loadBody(env!, post);
const saved = Astro.url.searchParams.has("saved");
const error = Astro.url.searchParams.get("error");
---

<Admin title={`Edit · ${post.title}`}>
	<div class="page-head">
		<h1 class="page-title">Edit post</h1>
		<a href={`/posts/${post.slug}`} target="_blank" class="view">View ↗</a>
	</div>
	<PostEditor
		id={post.id}
		title={post.title}
		slug={post.slug}
		excerpt={post.excerpt}
		visibility={post.visibility}
		body={body}
		tags={post.tags.map((t) => t.label).join(", ")}
		categories={post.categories.map((c) => c.label).join(", ")}
		saved={saved}
		error={error}
	/>
</Admin>

<style>
	.page-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1.5rem; }
	.page-title { font-size: 1.5rem; }
	.view { font-size: 0.85rem; }
</style>
