---
import Admin from "../../layouts/Admin.astro";
import { countUsers } from "../../lib/db";

const env = Astro.locals.env;
if (env && (await countUsers(env)) > 0) return Astro.redirect("/admin/login");
const error = Astro.url.searchParams.has("error");
---

<Admin title="Setup">
	<div class="auth">
		<h1>Create your admin account</h1>
		<p class="sub">First-run setup. This creates the single owner account.</p>
		{error && <div class="notice notice-error">Check your email and use a password of at least 8 characters.</div>}
		<form method="POST" action="/api/setup">
			<div class="field"><label for="name">Name</label><input id="name" name="name" autocomplete="name" /></div>
			<div class="field"><label for="email">Email</label><input id="email" name="email" type="email" required autocomplete="username" /></div>
			<div class="field"><label for="password">Password</label><input id="password" name="password" type="password" required minlength="8" autocomplete="new-password" /></div>
			<button type="submit" class="btn">Create account</button>
		</form>
	</div>
</Admin>

<style>
	.auth { max-width: 380px; margin: 3rem auto; }
	.auth h1 { font-size: 1.5rem; }
	.sub { color: var(--muted); font-size: 0.9rem; margin: 0.4rem 0 1.5rem; }
</style>
