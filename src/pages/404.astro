---
import Base from "../layouts/Base.astro";
---

<Base title="Not found" robots="noindex">
	<div class="nf">
		<p class="code">404</p>
		<h1>Page not found</h1>
		<p class="msg">That page doesn't exist, or it's private.</p>
		<a href="/" class="home-link">← Back home</a>
	</div>
</Base>

<style>
	.nf {
		max-width: var(--content-width);
		margin: 0 auto;
		padding: var(--spacing-24) var(--spacing-6);
		text-align: center;
	}
	.code {
		font-size: var(--font-size-5xl);
		font-weight: 700;
		color: var(--color-muted);
	}
	.msg {
		color: var(--color-text-secondary);
		margin: var(--spacing-3) 0 var(--spacing-8);
	}
</style>
