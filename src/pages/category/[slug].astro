---
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import { getTerm, listPosts } from "../../lib/content";

const env = Astro.locals.env;
const slug = Astro.params.slug!;
const term = env ? await getTerm(env, "categories", slug) : null;
if (!term) return new Response(null, { status: 404 });
const posts = await listPosts(env!, { category: slug, limit: 200 });
---

<Base title={term.label} description={`Posts in ${term.label}`}>
	<div class="archive">
		<header class="archive-header">
			<p class="kicker">Category</p>
			<h1>{term.label}</h1>
			<p class="count">{posts.length} {posts.length === 1 ? "post" : "posts"}</p>
		</header>
		<section class="post-list">
			{posts.map((p) => (
				<PostCard title={p.title} excerpt={p.excerpt} href={`/posts/${p.slug}`}
					date={p.published_at ?? p.created_at} readingTime={p.reading_time} tags={p.tags} />
			))}
		</section>
	</div>
</Base>

<style>
	.archive { max-width: var(--content-width); margin: 0 auto; padding: var(--spacing-16) var(--spacing-6); }
	.archive-header { margin-bottom: var(--spacing-8); }
	.kicker { text-transform: uppercase; letter-spacing: var(--tracking-wider); font-size: var(--font-size-xs); color: var(--color-muted); }
	.archive-header h1 { font-size: var(--font-size-3xl); margin-top: var(--spacing-2); }
	.count { color: var(--color-muted); font-size: var(--font-size-sm); margin-top: var(--spacing-2); }
</style>
