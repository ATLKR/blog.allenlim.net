---
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import { listPosts } from "../lib/content";
import { getSiteIdentity } from "../lib/site";

const env = Astro.locals.env;
const { title: siteTitle, tagline } = await getSiteIdentity(env);
const posts = env ? await listPosts(env, { limit: 20 }) : [];
---

<Base title={siteTitle} description={tagline}>
	<div class="home">
		<header class="intro">
			<h1 class="intro-title">{siteTitle}</h1>
			<p class="intro-tagline">{tagline}</p>
		</header>

		{posts.length === 0 ? (
			<p class="empty">No posts published yet.</p>
		) : (
			<section class="post-list">
				{posts.map((p) => (
					<PostCard
						title={p.title}
						excerpt={p.excerpt}
						href={`/posts/${p.slug}`}
						date={p.published_at ?? p.created_at}
						readingTime={p.reading_time}
						tags={p.tags}
					/>
				))}
			</section>
		)}
	</div>
</Base>

<style>
	.home {
		max-width: var(--content-width);
		margin: 0 auto;
		padding: var(--spacing-16) var(--spacing-6);
	}
	.intro {
		margin-bottom: var(--spacing-12);
	}
	.intro-title {
		font-size: var(--font-size-4xl);
	}
	.intro-tagline {
		margin-top: var(--spacing-3);
		color: var(--color-text-secondary);
		font-size: var(--font-size-lg);
	}
	.empty {
		color: var(--color-muted);
	}
</style>
