---
import Base from "../../layouts/Base.astro";
import { getPostMetaBySlug, isReachable, loadBody } from "../../lib/content";
import { renderMarkdown } from "../../lib/markdown";
import { formatDate } from "../../lib/site";

const env = Astro.locals.env;
const slug = Astro.params.slug!;
const loggedIn = !!Astro.locals.user;

const post = env ? await getPostMetaBySlug(env, slug) : null;
if (!post || !isReachable(post.visibility, loggedIn)) {
	return new Response(null, { status: 404 });
}

const body = await loadBody(env!, post);
const html = renderMarkdown(body);
const dateStr = formatDate(post.published_at ?? post.created_at);
// unlisted/private/draft must never be indexed
const robots = post.visibility === "public" ? null : "noindex, nofollow";
---

<Base
	title={post.title}
	description={post.excerpt}
	type="article"
	robots={robots}
>
	<article class="post">
		{post.visibility !== "public" && (
			<div class={`status-banner status-${post.visibility}`}>
				This post is <strong>{post.visibility}</strong> — only you can see it while logged in.
			</div>
		)}
		<header class="post-header">
			<div class="post-meta">
				{dateStr && <time>{dateStr}</time>}
				<span class="dot" />
				<span>{post.reading_time} min read</span>
			</div>
			<h1 class="post-title">{post.title}</h1>
			{post.categories.length > 0 && (
				<div class="post-cats">
					{post.categories.map((c) => <a href={`/category/${c.slug}`}>{c.label}</a>)}
				</div>
			)}
		</header>

		<div class="prose" set:html={html} />

		{post.tags.length > 0 && (
			<footer class="post-tags">
				{post.tags.map((t) => <a href={`/tag/${t.slug}`} class="tag">#{t.label}</a>)}
			</footer>
		)}
	</article>
</Base>

<style>
	.post {
		max-width: var(--content-width);
		margin: 0 auto;
		padding: var(--spacing-16) var(--spacing-6);
	}
	.status-banner {
		padding: var(--spacing-3) var(--spacing-4);
		border-radius: var(--radius);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		margin-bottom: var(--spacing-8);
	}
	.post-header {
		margin-bottom: var(--spacing-8);
	}
	.post-meta {
		display: flex;
		align-items: center;
		gap: var(--spacing-3);
		color: var(--color-muted);
		font-size: var(--font-size-sm);
		margin-bottom: var(--spacing-3);
	}
	.dot {
		width: 3px;
		height: 3px;
		border-radius: 50%;
		background: var(--color-muted);
	}
	.post-title {
		font-size: clamp(var(--font-size-3xl), 5vw, var(--font-size-4xl));
	}
	.post-cats {
		display: flex;
		gap: var(--spacing-2);
		margin-top: var(--spacing-4);
		font-size: var(--font-size-sm);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
	}
	.post-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
		margin-top: var(--spacing-12);
		padding-top: var(--spacing-6);
		border-top: 1px solid var(--color-border-subtle);
	}
	.tag {
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
	}
	.prose :global(p),
	.prose :global(ul),
	.prose :global(ol),
	.prose :global(blockquote),
	.prose :global(pre),
	.prose :global(h2),
	.prose :global(h3),
	.prose :global(h4) {
		margin-bottom: 1.4em;
	}
	.prose :global(h2) {
		font-size: var(--font-size-2xl);
		margin-top: 1.8em;
	}
	.prose :global(h3) {
		font-size: var(--font-size-xl);
		margin-top: 1.6em;
	}
	.prose :global(ul),
	.prose :global(ol) {
		padding-left: var(--spacing-6);
	}
	.prose :global(li) {
		margin-bottom: 0.4em;
	}
	.prose :global(blockquote) {
		padding-left: var(--spacing-6);
		border-left: 3px solid var(--color-border);
		color: var(--color-muted);
	}
	.prose :global(pre) {
		padding: var(--spacing-4);
		background: var(--color-surface);
		border-radius: var(--radius);
		overflow-x: auto;
		font-family: var(--font-mono, monospace);
		font-size: var(--font-size-sm);
	}
	.prose :global(code) {
		font-family: var(--font-mono, monospace);
		font-size: 0.9em;
		background: var(--color-surface);
		padding: 0.15em 0.3em;
		border-radius: var(--radius);
	}
	.prose :global(pre code) {
		background: none;
		padding: 0;
	}
	.prose :global(img) {
		border-radius: var(--radius);
		margin: 1.5em 0;
	}
	.prose :global(a) {
		text-decoration: underline;
		text-underline-offset: 2px;
	}
</style>
