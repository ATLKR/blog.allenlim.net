{
	"name": "allenlim-blog",
	"version": "0.2.0",
	"private": true,
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"dev": "vite dev --port 3000",
		"generate-routes": "tsr generate",
		"build": "vite build",
		"preview": "vite preview",
		"deploy": "vite build && wrangler deploy",
		"typecheck": "tsc --noEmit",
		"cf-typegen": "wrangler types",
		"db:migrate:local": "wrangler d1 migrations apply allenlim-blog-cms --local",
		"db:migrate:remote": "wrangler d1 migrations apply allenlim-blog-cms --remote"
	},
	"dependencies": {
		"@cloudflare/vite-plugin": "^1.26.0",
		"@tanstack/react-router": "latest",
		"@tanstack/react-start": "latest",
		"@tanstack/router-plugin": "^1.132.0",
		"marked": "^15.0.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260305.1",
		"@tanstack/router-cli": "^1.132.0",
		"@types/node": "^22.10.2",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"@vitejs/plugin-react": "^6.0.1",
		"typescript": "^6.0.2",
		"vite": "^8.0.0",
		"wrangler": "^4.70.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": ["esbuild", "workerd"]
	}
}
